rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 내부 전용 시스템 — 로그인한 사용자면 모두 접근 가능
    // (mails, drafts, contacts, userSettings, signup_requests 등 모든 컬렉션 + 서브컬렉션 포함)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
