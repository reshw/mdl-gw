rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 수신/발신 메일 — 로그인한 사용자면 접근 가능 (내부 전용)
    match /mails/{mailId} {
      allow read, write: if request.auth != null;
    }

    // 임시저장 — 본인 문서만 (mailEmail 클레임 또는 email 클레임 허용)
    match /drafts/{draftId} {
      allow read, update, delete: if request.auth != null
        && (request.auth.token.mailEmail == resource.data.userEmail
         || request.auth.token.email == resource.data.userEmail);
      allow create: if request.auth != null
        && (request.auth.token.mailEmail == request.resource.data.userEmail
         || request.auth.token.email == request.resource.data.userEmail);
    }

    // 라벨 — 본인 라벨만 (mailEmail 클레임 또는 email 클레임 허용)
    match /labels/{labelId} {
      allow read, update, delete: if request.auth != null
        && (request.auth.token.mailEmail == resource.data.userEmail
         || request.auth.token.email == resource.data.userEmail);
      allow create: if request.auth != null
        && (request.auth.token.mailEmail == request.resource.data.userEmail
         || request.auth.token.email == request.resource.data.userEmail);
    }

    // 분류 규칙 — 본인 규칙만
    match /rules/{ruleId} {
      allow read, update, delete: if request.auth != null
        && (request.auth.token.mailEmail == resource.data.userEmail
         || request.auth.token.email == resource.data.userEmail);
      allow create: if request.auth != null
        && (request.auth.token.mailEmail == request.resource.data.userEmail
         || request.auth.token.email == request.resource.data.userEmail);
    }

    // mdl 멤버 목록 — 읽기는 로그인 사용자 전체, 쓰기는 서버(admin SDK)만
    match /members/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 개인 주소록 — 본인만 (mailEmail 클레임 또는 email 클레임 허용)
    match /contacts/{ownerEmail}/personal/{docId} {
      allow read, write: if request.auth != null
        && (request.auth.token.mailEmail == ownerEmail
         || request.auth.token.email == ownerEmail);
    }

    // 전체 주소록 — 읽기는 로그인 사용자 전체, 쓰기는 관리자만
    match /contacts/global/entries/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.isAdmin == true
         || request.auth.token.email == "reshw@naver.com"
         || request.auth.token.mailEmail == "reshw@naver.com");
    }

    // 가입 신청 — 관리자만
    match /signup_requests/{docId} {
      allow read, write: if request.auth != null
        && (request.auth.token.isAdmin == true
         || request.auth.token.email == "reshw@naver.com"
         || request.auth.token.mailEmail == "reshw@naver.com");
    }

    // 수신확인 트래킹 — 로그인한 사용자 읽기 허용 (쓰기는 서버만)
    match /tracking/{trackId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 이메일 변경 OTP 요청 — 서버(admin SDK)만 읽기/쓰기
    match /email_change_requests/{uid} {
      allow read, write: if false;
    }

    // 테넌트 설정 — 본인 문서 읽기만 허용 (daemon_error 등 상태 수신용)
    match /tenants/{email} {
      allow read: if request.auth != null
        && (request.auth.token.mailEmail == email
         || request.auth.token.email == email);
      allow write: if false;
    }
  }
}
